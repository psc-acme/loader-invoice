{
    "name": "psc-acme/loader-invoice",
    "description": "Package loader-invoice for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\LoaderInvoice\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/dotenv": "^7.0",
        "league/commonmark": "^2.0",
        "psr/container": "^2.0",
        "laravel/framework": "^11.0",
        "symfony/routing": "^7.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "behat/behat": "^3.14"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}